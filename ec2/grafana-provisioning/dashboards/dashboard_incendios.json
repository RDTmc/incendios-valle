{
  "id": null,
  "uid": "incendios-valle-main",
  "title": "Incendios Valle del Sol",
  "tags": ["incendios", "valle-del-sol", "produccion"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Focos Críticos Activos",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [{
        "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
        "refId": "A",
        "rawSql": "SELECT COUNT(*) AS \"Focos Activos\" FROM reports WHERE estado IN ('ACTIVO', 'PENDIENTE')",
        "format": "table"
      }]
    },
    {
      "id": 2,
      "title": "Distribución por Tipo de Incendio",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
      "fieldConfig": {
        "defaults": { "mappings": [], "unit": "none" },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [{
        "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
        "refId": "A",
        "rawSql": "SELECT COALESCE(NULLIF(tipo, ''), 'SIN TIPO') AS \"Tipo\", COUNT(*) AS \"Cantidad\" FROM reports GROUP BY \"Tipo\" ORDER BY \"Cantidad\" DESC",
        "format": "table"
      }]
    },
    {
      "id": 3,
      "title": "Estatus Global de Reportes",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": [],
          "unit": "none",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [{
        "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
        "refId": "A",
        "rawSql": "SELECT COALESCE(SUM(CASE WHEN estado = 'PENDIENTE' THEN 1 ELSE 0 END), 0) AS \"Pendiente\", COALESCE(SUM(CASE WHEN estado = 'ACTIVO' THEN 1 ELSE 0 END), 0) AS \"Activo\", COALESCE(SUM(CASE WHEN estado = 'CONTROLADO' THEN 1 ELSE 0 END), 0) AS \"Controlado\" FROM reports WHERE estado IN ('ACTIVO', 'PENDIENTE', 'CONTROLADO')",
        "format": "table"
      }]
    },
    {
      "id": 4,
      "title": "Mapa de Calor - Focos de Incendio",
      "type": "geomap",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "view": { "lat": -33.45, "lng": -70.66, "zoom": 10 },
        "controls": { "showZoom": true, "showAttribution": false },
        "layers": [{
          "name": "Heatmap",
          "type": "heatmap",
          "location": { "mode": "auto" },
          "heatmap": { "radius": 20, "blur": 15 }
        }]
      },
      "targets": [{
        "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
        "refId": "A",
        "rawSql": "SELECT CAST(latitud AS REAL) AS \"latitude\", CAST(longitud AS REAL) AS \"longitude\", CASE estado WHEN 'ACTIVO' THEN 3 WHEN 'PENDIENTE' THEN 2 WHEN 'CONTROLADO' THEN 1 ELSE 0 END AS \"intensidad\", COALESCE(NULLIF(estado, ''), 'DESCONOCIDO') AS \"estado\", COALESCE(NULLIF(tipo, ''), 'SIN TIPO') AS \"tipo\" FROM reports WHERE latitud IS NOT NULL AND latitud != '' AND longitud IS NOT NULL AND longitud != '' AND CAST(latitud AS REAL) != 0 AND CAST(longitud AS REAL) != 0",
        "format": "table"
      }]
    },
    {
      "id": 5,
      "title": "Clústeres Detectados",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [{
        "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
        "refId": "A",
        "rawSql": "SELECT COUNT(*) AS \"clusters\" FROM (SELECT a.report_id FROM reports a JOIN reports b ON a.report_id < b.report_id AND ABS(CAST(a.latitud AS REAL) - CAST(b.latitud AS REAL)) < 0.0005 AND ABS(CAST(a.longitud AS REAL) - CAST(b.longitud AS REAL)) < 0.0005 WHERE a.created_at >= datetime('now', '-1 day'))",
        "format": "table"
      }]
    },
    {
      "id": 6,
      "title": "Pendientes Estancados (>30 min)",
      "type": "table",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 24 },
      "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 30 }
            ]
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "minutos" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "red", "value": 30 }
                ]
              }}
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "targets": [{
        "datasource": { "type": "sqlite3", "uid": "incendios-sqlite" },
        "refId": "A",
        "rawSql": "SELECT report_id, created_at AS \"creado\", ROUND((julianday('now') - julianday(created_at)) * 1440) AS \"minutos\" FROM reports WHERE estado = 'PENDIENTE' AND (julianday('now') - julianday(created_at)) * 1440 > 30 ORDER BY \"minutos\" DESC",
        "format": "table"
      }]
    }
  ]
}