        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "pg-incendios"
          },
          "rawSql": "SELECT w1.region AS \"Region\", ROUND(w1.temperature::numeric, 1) AS \"Temp\", w1.humidity AS \"Hum\", ROUND((w1.wind_speed * 3.6)::numeric, 0) AS \"Viento\", CASE WHEN w1.temperature > 30 AND w1.humidity < 30 AND w1.wind_speed * 3.6 > 30 THEN 2 WHEN w1.temperature > 25 OR w1.humidity < 40 OR w1.wind_speed * 3.6 > 25 THEN 1 ELSE 0 END AS \"Riesgo\" FROM weather_readings w1 WHERE w1.id = (SELECT MAX(w2.id) FROM weather_readings w2 WHERE w2.region = w1.region) ORDER BY w1.region",
          "format": "table"
        }
      ],
      "title": "Clima 30-30-30",
      "type": "table"
