          "refId": "B",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "pg-incendios"
          },
          "rawSql": "SELECT r.latitud AS lat, r.longitud AS lng, ir.tipo_recurso AS \"Recurso\", ir.estado AS \"Estado\", ir.cantidad AS \"Cant\", SUBSTR(ir.report_id, 1, 8) AS \"Reporte\", r.tipo AS \"Tipo\", r.descripcion AS \"Direccion\" FROM incident_resources ir LEFT JOIN reports r ON ir.report_id = r.report_id WHERE r.latitud IS NOT NULL AND r.latitud != '' AND r.longitud IS NOT NULL AND r.longitud != '' ORDER BY ir.created_at DESC",
          "format": "table"
        }
