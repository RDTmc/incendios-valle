    {
      "id": 6,
      "title": "Alertas Recientes",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "incendios-sqlite" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "read" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixed": {
                    "0": "#FF9800",
                    "1": "#4CAF50"
                  }
                }
              },
              {
                "id": "displayName",
                "value": "Leída"
              }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "md",
        "footer": {
          "countRows": false,
          "enablePagination": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "created_at" }]
      },
      "targets": [
        {
          "rawSql": "SELECT alert_type AS \"Tipo\", message AS \"Mensaje\", created_at AS \"Fecha\", read FROM alerts ORDER BY created_at DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    }
