      "options": {
        "sortBy": [{ "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [{
        "rawSql": "SELECT alert_type, message, created_at, read FROM alerts ORDER BY created_at DESC LIMIT 20",
        "format": "table",
        "refId": "A"
      }]
    }
